.chat-container {
  display: flex;
  flex-direction: column;
  height: 100vh;
}

.messages {
  flex: 1;
  padding: 20rpx 30rpx;
  padding-bottom: 20rpx;
}

.message-row {
  display: flex;
  margin-bottom: 24rpx;
}

.message-row.left {
  justify-content: flex-start;
}

.message-row.right {
  justify-content: flex-end;
}

.bubble {
  max-width: 75%;
  padding: 20rpx 28rpx;
  border-radius: 24rpx;
  font-size: 30rpx;
  line-height: 1.6;
  word-wrap: break-word;
}

.bubble.assistant {
  background-color: #1e1e3a;
  color: #d0d0e8;
  border-bottom-left-radius: 8rpx;
}

.bubble.user {
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  color: #ffffff;
  border-bottom-right-radius: 8rpx;
}

.bubble.typing {
  opacity: 0.6;
}

.input-area {
  padding: 20rpx 30rpx;
  padding-bottom: calc(20rpx + env(safe-area-inset-bottom));
  background-color: #16162a;
  border-top: 1rpx solid #2a2a4a;
}

.end-hint {
  text-align: center;
  font-size: 24rpx;
  color: #6a6a8a;
  margin-bottom: 16rpx;
}

.end-link {
  color: #667eea;
  font-weight: 500;
}

.input-row {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.input {
  flex: 1;
  background-color: #1e1e3a;
  border-radius: 36rpx;
  padding: 16rpx 28rpx;
  font-size: 30rpx;
  color: #e0e0e0;
}

.placeholder {
  color: #4a4a6a;
}

.send-btn {
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  color: #ffffff;
  border: none;
  border-radius: 36rpx;
  padding: 16rpx 32rpx;
  font-size: 28rpx;
  min-width: 120rpx;
}

.send-btn[disabled] {
  opacity: 0.4;
}
